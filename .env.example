# Wincher MCP Server Configuration
# 
# Get your API key from Wincher:
# 1. Log into https://www.wincher.com
# 2. Go to Settings → Personal Access Tokens
# 3. Click "Generate New Token"
# 4. Copy the token and paste it below
#
# Instructions:
# 1. Copy this file to .env (cp .env.example .env)
# 2. Replace the placeholder below with your actual API key
# 3. Never commit .env to version control

WINCHER_API_KEY=your_wincher_api_key_here

# Optional: only when MCP args include --use-staging (never commit real values)
# WINCHER_STAGING_API_KEY=
# WINCHER_STAGING_API_HOST=

# Optional: add --use-toon to MCP server args for compact TOON responses (fewer LLM tokens).
# Per-call override: pass output_format "text" or "toon" on any tool.
